                                   },
                       "id":  2,
                       "targets":  [
                                       {
                                           "format":  "table",
                                           "rawQuery":  true,
                                           "rawSql":  "WITH base AS (SELECT pays, date, ratio_liquidite, encours_credits, LAG(encours_credits) OVER (PARTITION BY pays ORDER BY date) AS prev_credit FROM indicateurs_liquidite WHERE date \u003e= NOW()::date - INTERVAL \u00273 years\u0027), points AS (SELECT pays, date, ratio_liquidite, CASE WHEN prev_credit IS NULL OR prev_credit = 0 THEN NULL ELSE ((encours_credits - prev_credit) / prev_credit) * 100 END AS croissance_credit_pct FROM base) SELECT croissance_credit_pct AS x, ratio_liquidite AS y, pays AS \"Pays (proxy secteur bancaire)\" FROM points WHERE croissance_credit_pct IS NOT NULL ORDER BY date;",
                                           "refId":  "A"
                                       }
                                   ],
                       "title":  "Correlation credit / liquidite (scatter)",
                       "type":  "xychart"
                   },
                   {
                       "datasource":  {
                                          "type":  "postgres",
                                          "uid":  "bfezxt7mkxqf4f"
                                      },
