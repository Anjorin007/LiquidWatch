                                       "x":  12,
                                       "y":  8
                                   },
                       "id":  3,
                       "targets":  [
                                       {
                                           "format":  "table",
                                           "rawQuery":  true,
                                           "rawSql":  "SELECT pays AS \"Pays (proxy secteur bancaire)\", EXTRACT(MONTH FROM date)::int AS mois, AVG(ratio_liquidite) AS ratio_moyen FROM indicateurs_liquidite GROUP BY pays, EXTRACT(MONTH FROM date) ORDER BY pays, mois;",
                                           "refId":  "A"
                                       }
                                   ],
