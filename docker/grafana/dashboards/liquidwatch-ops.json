                                           "rawSql":  "WITH latest_model AS (SELECT model_version FROM predictions_liquidite WHERE pays = ${country:singlequote} ORDER BY created_at DESC LIMIT 1), hist AS (SELECT date AS time, ratio_liquidite AS value, \u0027Historique\u0027::text AS metric FROM indicateurs_liquidite WHERE pays = ${country:singlequote} AND date \u003e= NOW()::date - INTERVAL \u002736 months\u0027), pred AS (SELECT prediction_date AS time, yhat AS value, \u0027Prediction\u0027::text AS metric FROM predictions_liquidite p JOIN latest_model m ON p.model_version = m.model_version WHERE p.pays = ${country:singlequote} AND p.horizon_days BETWEEN 1 AND 30), lo95 AS (SELECT prediction_date AS time, yhat_lower_95 AS value, \u0027IC95_bas\u0027::text AS metric FROM predictions_liquidite p JOIN latest_model m ON p.model_version = m.model_version WHERE p.pays = ${country:singlequote} AND p.horizon_days BETWEEN 1 AND 30), up95 AS (SELECT prediction_date AS time, yhat_upper_95 AS value, \u0027IC95_haut\u0027::text AS metric FROM predictions_liquidite p JOIN latest_model m ON p.model_version = m.model_version WHERE p.pays = ${country:singlequote} AND p.horizon_days BETWEEN 1 AND 30) SELECT * FROM hist UNION ALL SELECT * FROM pred UNION ALL SELECT * FROM lo95 UNION ALL SELECT * FROM up95 ORDER BY time;",
