                                           "rawSql":  "WITH recent AS (SELECT date, actifs_liquides, passifs_court_terme FROM indicateurs_liquidite WHERE pays = ${country:singlequote} ORDER BY date DESC LIMIT 240), ordered AS (SELECT date AS time, actifs_liquides, passifs_court_terme FROM recent ORDER BY date), diff AS (SELECT time, actifs_liquides - LAG(actifs_liquides) OVER (ORDER BY time) AS delta_actifs, passifs_court_terme - LAG(passifs_court_terme) OVER (ORDER BY time) AS delta_passifs FROM ordered) SELECT time, GREATEST(COALESCE(delta_actifs, 0), 0) AS inflows, -GREATEST(COALESCE(delta_passifs, 0), 0) AS outflows FROM diff ORDER BY time;",
